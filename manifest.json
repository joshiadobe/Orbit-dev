{
  "manifest_version": 3,
  "name": "Volt",
  "version": "1.0",
  "description": "AI assistant for Dynamics tickets",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": [
    "storage",
    "identity",
    "alarms"
  ],

  "host_permissions": [
    "https://adobe.okta.com/*",
    "https://adobe-stage.okta.com/*",
    "https://orbit.corp.adobe.com/*",
    "https://fluffyjaws.adobe.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://adobe-ent.crm.dynamics.com/*",
        "https://*.crm.dynamics.com/*"
      ],

      "js": [
        "markdown-it.min.js",
        "content.js",
        "analytics.js"
      ],

      "css": [
        "styles.css"
      ],

      "run_at": "document_idle"
    }
  ]
}