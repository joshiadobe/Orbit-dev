{
  "manifest_version": 3,
  "name": "Orbit",
  "version": "8.0",
  "description": "AI assistant for Dynamics tickets",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://10.51.242.50:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://adobe-ent.crm.dynamics.com/*",
        "https://*.crm.dynamics.com/*"
      ],
      "js": [
        "markdown-it.min.js",
        "content.js",
        "analytics.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}